<launch>

    <let name="urdf_path"
         value="$(find-pkg-share rover_arm_description)/urdf/arm.urdf.xacro"/>

    <let name="rviz_config_path"
         value="$(find-pkg-share rover_arm_description)/rviz/urdf_config.rviz"/>

    <let name="controller_manager_path"
         value="$(find-pkg-share rover_arm_bringup)/config/ros2_controllers.yaml"/>

    <let name="servo_config_bringup"
         value="$(find-pkg-share rover_arm_bringup)/config/servo_config.yaml"/>

    <node pkg="robot_state_publisher" exec="robot_state_publisher" output="screen">
        <param name="robot_description"
               value="$(command 'xacro $(var urdf_path)')" />
    </node>

    <node pkg="controller_manager" exec="ros2_control_node"
          args="-d $(var controller_manager_path)"
          output="screen"/>

    <node pkg="controller_manager" exec="spawner"
          args="joint_state_broadcaster"
          output="screen"/>

    <node pkg="controller_manager" exec="spawner"
          args="arm_controller"
          output="screen"/>

    <node pkg="moveit_servo" exec="servo_node_main" output="screen">
        <param name="servo_config" value="$(var servo_config_bringup)"/>
        <param from="$(find-pkg-share rover_arm_bringup)/config/rover_arm.srdf"/>
    </node>

    <node pkg="rviz2" exec="rviz2"
          args="-d $(var rviz_config_path)"
          output="screen"/>

</launch>