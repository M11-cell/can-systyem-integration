<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name="rover_arm_ros2_control" params="name initial_positions_file">
        <xacro:property name="initial_positions" value="${load_yaml(initial_positions_file)['initial_positions']}"/>

       <ros2_control name="RoverArm" type="system">
          <hardware>
            <!--
              CAN-based hardware interface. The legacy serial plugin
              (arm_interface/ArmInterface) is preserved in the arm_hardware
              package for reference but is no longer wired here.
            -->
            <plugin>arm_can_hardware/ArmCanInterface</plugin>
            <param name="can_interface">can0</param>
            <param name="send_heartbeat_on_activate">true</param>
          </hardware>

            <!-- Per-joint parameters tell ArmCanInterface which CAN motor /
                 encoder a URDF joint maps onto. arm_instruction values come
                 from Instructions::Inst in can-utils/prefixes.hpp. -->
            <joint name="joint1">
                <param name="kind">arm_motor</param>
                <param name="arm_instruction">0x12</param>      <!-- ARM_MOTOR_1 -->
                <param name="encoder_device_id">0x07</param>    <!-- BASE_ENCODER -->
                <param name="velocity_scale">1.0</param>
                <command_interface name="velocity"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['joint1']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="joint2">
                <param name="kind">arm_motor</param>
                <param name="arm_instruction">0x14</param>      <!-- ARM_MOTOR_2 -->
                <param name="encoder_device_id">0x08</param>    <!-- SHOULDER_ENCODER -->
                <param name="velocity_scale">1.0</param>
                <command_interface name="velocity"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['joint2']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="joint3">
                <param name="kind">arm_motor</param>
                <param name="arm_instruction">0x16</param>      <!-- ARM_MOTOR_3 -->
                <param name="encoder_device_id">0x09</param>    <!-- ELBOW_ENCODER -->
                <param name="velocity_scale">1.0</param>
                <command_interface name="velocity"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['joint3']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="joint5">
                <param name="kind">arm_motor</param>
                <param name="arm_instruction">0x1A</param>      <!-- ARM_MOTOR_5 -->
                <param name="encoder_device_id">0x0B</param>    <!-- WRIST_ENCODER -->
                <param name="velocity_scale">1.0</param>
                <command_interface name="velocity"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['joint5']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>

        </ros2_control>
    </xacro:macro>
</robot>
